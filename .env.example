NVIDIA_API_KEY=
# Hosted NVIDIA Build/API keys currently expose stable-diffusion-3-medium in the public visual-model catalog.
# For self-hosted NIM, keep your 3.5 Large model name and point NVIDIA_API_BASE_URL at your NIM endpoint instead.
NVIDIA_IMAGE_MODEL=stabilityai/stable-diffusion-3-medium
NVIDIA_API_BASE_URL=https://ai.api.nvidia.com/v1/genai/stabilityai/stable-diffusion-3-medium
NEXT_PUBLIC_APP_URL=http://localhost:3000
